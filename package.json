{
  "name": "tekoinnova-cmd",
  "version": "0.1.0",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "node scripts/clean-next.mjs && next build",
    "electron:prepare": "node scripts/prepare-electron.mjs && node scripts/generate-win-icon.mjs",
    "electron:build": "npm run build && npm run electron:prepare && electron-builder",
    "electron:build:win": "npm run build && npm run electron:prepare && electron-builder --win nsis",
    "electron:start": "npm run build && npm run electron:prepare && electron .",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@sentry/nextjs": "^10.48.0",
    "@types/jszip": "^3.4.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.1",
    "embedded-postgres": "^18.3.0-beta.17",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "otpauth": "^9.5.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "png-to-ico": "^2.1.8",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "com.tekoga.app",
    "productName": "TEKOGA",
    "artifactName": "TEKOGA Setup ${version}.${ext}",
    "icon": "build/tekoga.ico",
    "directories": {
      "output": "release/tekoga-build"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-electron/app",
        "to": "app",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/cloudflared.exe",
        "to": "cloudflared.exe"
      }
    ],
    "asar": true,
    "win": {
      "icon": "build/tekoga.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TEKOGA"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --max-warnings=0"
  }
}
