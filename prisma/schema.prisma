// ============================================================
// TEKOINNOVA Centro de Mando — Schema Prisma
// Arquitectura: Hub & Spoke | 6 Módulos ERP/SaaS
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

