// BASE DE DATOS MAESTRA — NO se altera al crear proyectos
// ============================================================

/// Unidad de medida reutilizable (m², m³, kg, u, ml, etc.)
model UnidadMedida {
  id     String @id @default(cuid())
  nombre String @unique // "m²", "m³", "kg", "u", "ml"
  simbolo String

  // Relaciones
  materialesMaestros    MaterialMaestro[]
  rubrosMaestros        RubroMaestro[]
  insumos               Insumo[]
  recetasMaestraDetalle RecetaMaestraDetalle[]

  @@map("unidad_medida")
}

/// Categoría de material (Hormigón, Mampostería, Cubierta, etc.)
model CategoriaMaterial {
  id     String @id @default(cuid())
  nombre String @unique

  materialesMaestros MaterialMaestro[]

  @@map("categoria_material")
}

/// Material de la Base de Datos Maestra
/// NUNCA se edita directamente desde un Proyecto
model MaterialMaestro {
  id          String  @id @default(cuid())
  codigo      String  @unique // Ej: "LAD-001"
  nombre      String
  descripcion String?
  precioBase  Float   // Precio de referencia maestro
  activo      Boolean @default(true)

  unidadMedidaId  String
  unidadMedida    UnidadMedida      @relation(fields: [unidadMedidaId], references: [id])
  categoriaId     String?
  categoria       CategoriaMaterial? @relation(fields: [categoriaId], references: [id])

  // Cada material maestro puede aparecer en muchas recetas maestras
  recetasMaestras RecetaMaestraDetalle[]

  // Módulo Inventario
  recepcionesBodega RecepcionBodega[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("material_maestro")
}

/// Categoría de Rubro (Estructura, Terminaciones, Instalaciones, etc.)
model CategoriaRubro {
  id     String @id @default(cuid())
  nombre String @unique
  orden  Int    @default(0)

  rubrosMaestros RubroMaestro[]

  @@map("categoria_rubro")
}

/// Rubro de la Base de Datos Maestra
/// Ej: "Losa de H°A° e=0.20m", "Mampostería de ladrillo"
model RubroMaestro {
  id          String  @id @default(cuid())
  codigo      String  @unique // Ej: "EST-001"
  nombre      String
  descripcion String?
  activo      Boolean @default(true)

  unidadMedidaId String
  unidadMedida   UnidadMedida @relation(fields: [unidadMedidaId], references: [id])
  categoriaId    String?
  categoria      CategoriaRubro? @relation(fields: [categoriaId], references: [id])

  // La receta maestra: lista de materiales y mano de obra para 1 unidad de este rubro
  recetaDetalle RecetaMaestraDetalle[]

  // Cuando se crea un proyecto, se copian los rubros del maestro
  rubrosProyecto RubroProyecto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rubro_maestro")
}

/// Detalle de la Receta Maestra (ingredientes por unidad de rubro)
/// REGLA: porcPerdida se aplica a la CANTIDAD, nunca al precio
model RecetaMaestraDetalle {
  id             String  @id @default(cuid())
  cantidad       Float   // Cantidad base por unidad del rubro
  porcPerdida    Float   @default(0) // % pérdida/desperdicio → se aplica a cantidad
  esManodeObra   Boolean @default(false)
  descripcionMO  String? // Descripción si es mano de obra

  rubroMaestroId   String
  rubroMaestro     RubroMaestro @relation(fields: [rubroMaestroId], references: [id], onDelete: Cascade)
  materialMaestroId String?
  materialMaestro   MaterialMaestro? @relation(fields: [materialMaestroId], references: [id])
  unidadMedidaId   String?
  unidadMedida     UnidadMedida? @relation(fields: [unidadMedidaId], references: [id])

  @@map("receta_maestra_detalle")
}

// ============================================================
// CONFIGURACIÓN GLOBAL — EMPRESA / FIRMA
// ============================================================

/// Datos de la empresa/estudio de arquitectura (registro único global)
/// Se usa como cabezalero en todos los informes y exportaciones
model Empresa {
  id        String  @id @default(cuid())
  nombre    String
  titulo    String? // Eslogan o leyenda
  direccion String?
  telefono  String?
  email     String?
  web       String?
  ciudad    String?
  pais      String?
  logoUrl   String? // URL o path relativo del logo

  proyectos   Proyecto[]
  usuarios    Usuario[]
  proveedores Proveedor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("empresa")
}

// ============================================================
// MÓDULO 1 — PROYECTO (FICHA TÉCNICA)
// ============================================================

enum EstadoProyecto {
  ANTEPROYECTO
  BORRADOR
  PROYECTO_EJECUTIVO
  CONTRATO_CONFIRMADO
  PRESUPUESTADO
  EN_EJECUCION
  PAUSADO
  FINALIZADO
  CANCELADO
  OTRO
}

/// Proyecto principal — núcleo del Hub & Spoke
model Proyecto {
  id              String         @id @default(cuid())
  codigo          String         @unique // Ej: "PRY-2026-001"
  nombre          String
  descripcion     String?
  ubicacion       String?
  superficieM2    Float?   // Superficie a construir (m²) — base para costo/m²
  superficieTerreno Float? // Superficie del terreno (m²)
  fechaInicio     DateTime?
  fechaFinEstimada DateTime?
  duracionSemanas Int?           // Duración planificada en semanas
  estado          EstadoProyecto @default(ANTEPROYECTO)

  // Empresa/estudio responsable (cabezalero de informes)
  empresaId       String?
  empresa         Empresa?       @relation(fields: [empresaId], references: [id])

  // Módulo 1 sub-modelos
  propietarios    Propietario[]
  equipoTecnico   MiembroEquipo[]
  laminas         LaminaPlano[]

  // Módulo 2: rubros del presupuesto (copia de maestros)
  rubrosProyecto  RubroProyecto[]

  // Módulo 3: cronograma
  cronograma      MicrocicloTarea[]

  // Módulo 4: contratos de mano de obra
  contratosMO     ContratoManoObra[]

  // Módulo 5: costos indirectos
  costosIndirectos CostoIndirecto[]

  // Módulo 6: plan de pagos
  planPagos       CuotaPago[]

  // Gestión extendida del proyecto
  reuniones       Reunion[]
  anotaciones     Anotacion[]
  aprobacion      AprobacionProyecto?

  // Módulo 7: Estado Financiero
  movimientosFinancieros MovimientoFinanciero[]
  trabajosAdicionales    TrabajoAdicional[]
  // Módulo 8: Proveedores y Compras
  facturasProveedores    FacturaProveedor[]

  // Módulo 9: Inventario / As-Built
  ambientes              AmbienteProyecto[]
  recepcionesBodega      RecepcionBodega[]

    // Módulo 10: Bitácora de Obra
    bitacoraEntradas       BitacoraEntrada[]
  formaPago            String?  // Ej: "Anticipo 30% + cuotas mensuales"
  objetoContrato       String?  // Descripción corta del objeto del contrato
  fechaContrato        DateTime?
  responsableObra      String?  // Nombre del Director/Responsable de Obra
  contactoPropietario  String?  // Teléfono o email de referencia rápida

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
  @@index([estado])
  @@map("proyecto")
}

/// Trabajo adicional fuera del contrato original
/// Suma al monto total a cobrar al cliente
model TrabajoAdicional {
  id          String    @id @default(cuid())
  descripcion String
  monto       Float
  fechaInicio DateTime?
  fechaFin    DateTime?
  aprobado    Boolean   @default(false)
  observacion String?

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("trabajo_adicional")
}

/// Hasta 5 propietarios por proyecto
model Propietario {
  id         String  @id @default(cuid())
  nombre     String
  apellido   String  @default("")
  direccion  String?
  dni        String?
  telefono   String?
  email      String?
  porcentaje Float   @default(100) // % de participación en propiedad

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@map("propietario")
}

enum RolEquipo {
  DIRECTOR_OBRA
  ARQUITECTO
  INGENIERO_ESTRUCTURAL
  INGENIERO_INSTALACIONES
  MAESTRO_MAYOR
  OTRO
}

/// Equipo técnico responsable del proyecto
model MiembroEquipo {
  id        String    @id @default(cuid())
  nombre    String
  apellido  String
  rol       RolEquipo
  titulo    String?   // Cargo o profesión: "Arq.", "Ing. Civil", custom
  telefono  String?
  email     String?
  matricula String?

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@map("miembro_equipo")
}

/// Índice dinámico de láminas de planos (A01, E02, etc.)
model LaminaPlano {
  id          String  @id @default(cuid())
  codigo      String  // Ej: "A01", "E02", "I-01"
  titulo      String
  disciplina  String  // Arquitectura, Estructura, Instalaciones, etc.
  revision    String  @default("0")
  urlArchivo  String? // Ruta o URL del archivo

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@map("lamina_plano")
}

// ============================================================
// MÓDULO 2 — CÓMPUTO Y PRESUPUESTO
// ============================================================

/// Rubro COPIADO del maestro al proyecto
/// Editar aquí NO altera el RubroMaestro original
model RubroProyecto {
  id          String  @id @default(cuid())
  orden       Int     @default(0) // Para ordenar en la planilla
  cantidad    Float   // Cómputo métrico del proyecto
  // Márgenes aplicados sobre el Subtotal de Costo Directo
  porcImprevistos Float @default(0) // %
  porcGanancia    Float @default(0) // %
  activo      Boolean @default(true)

  // Referencia al maestro (solo lectura, para trazabilidad)
  rubroMaestroId String
  rubroMaestro   RubroMaestro @relation(fields: [rubroMaestroId], references: [id])

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  // La receta COPIADA y editable dentro del proyecto
  insumos Insumo[]

  // Tareas de cronograma asociadas
  tareasCronograma MicrocicloTarea[]

  // Contratos MO asociados (muchos a muchos)
  contratosMO ContratoRubroProyecto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([proyectoId])
  @@index([rubroMaestroId])
  @@map("rubro_proyecto")
}

/// Insumo = copia editable de RecetaMaestraDetalle dentro del proyecto
/// REGLA CRÍTICA: porcPerdida afecta CANTIDAD, no precio
/// cantidadConPerdida = cantidad * rubroProyecto.cantidad * (1 + porcPerdida/100)
/// costoTotal = cantidadConPerdida * precioUnitario
model Insumo {
  id             String  @id @default(cuid())
  nombre         String  // Nombre editable (copiado del material maestro)
  cantidad       Float   // Cantidad por unidad de rubro (copiada, editable)
  porcPerdida    Float   @default(0) // % → se aplica a cantidad
  precioUnitario Float   // Precio editable (por defecto del maestro al copiar)
  esPrecioCustom Boolean @default(false) // true si el usuario alteró el precio
  esManodeObra   Boolean @default(false)
  descripcionMO  String?

  unidadMedidaId String?
  unidadMedida   UnidadMedida? @relation(fields: [unidadMedidaId], references: [id])

  rubroProyectoId String
  rubroProyecto   RubroProyecto @relation(fields: [rubroProyectoId], references: [id], onDelete: Cascade)

  @@index([rubroProyectoId])
  @@map("insumo")
}

// ============================================================
// MÓDULO 3 — CRONOGRAMA Y AVANCES (CURVA S)
// ============================================================

/// Tarea de microciclo: asigna días de inicio/duración a un rubro del proyecto
model MicrocicloTarea {
  id            String   @id @default(cuid())
  nombre        String   // Nombre descriptivo de la tarea
  diaInicio     Int      // Día relativo al inicio del proyecto (1-based)
  duracionDias  Int      // Duración en días
  // Los mesociclos (semanas/meses) se calculan en runtime a partir de diaInicio+duracion

  rubroProyectoId String
  rubroProyecto   RubroProyecto @relation(fields: [rubroProyectoId], references: [id], onDelete: Cascade)

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  avances AvanceTarea[]

  @@index([proyectoId])
  @@index([rubroProyectoId])
  @@map("microciclo_tarea")
}

/// Registro de avance real para la Curva S
model AvanceTarea {
  id            String   @id @default(cuid())
  fecha         DateTime
  porcentajeReal Float   // % de avance real registrado (0-100)
  observacion   String?

  microcicloTareaId String
  microcicloTarea   MicrocicloTarea @relation(fields: [microcicloTareaId], references: [id], onDelete: Cascade)

  @@map("avance_tarea")
}

// ============================================================
// MÓDULO 4 — GESTIÓN DE MANO DE OBRA
// ============================================================

enum EstadoContrato {
  ACTIVO
  PAUSADO
  FINALIZADO
  RESCINDIDO
}

/// Contrato de mano de obra por cuadrilla
model ContratoManoObra {
  id                String         @id @default(cuid())
  descripcion       String
  jefeCuadrilla     String
  montoPactado      Float          // Monto total del contrato
  porcRetencion     Float          @default(0) // % de retención de garantía
  estado            EstadoContrato @default(ACTIVO)
  fechaInicio       DateTime?
  fechaFinEstimada  DateTime?

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  personal    PersonalCuadrilla[]
  pagos       PagoContrato[]
  movimientos MovimientoFinanciero[]

  // Rubros asignados a este contrato (muchos a muchos)
  rubrosAsignados ContratoRubroProyecto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([proyectoId])
  @@index([estado])
  @@map("contrato_mano_obra")
}

/// Tabla pivote: ContratoManoObra ↔ RubroProyecto (M:M)
model ContratoRubroProyecto {
  contratoId      String
  contrato        ContratoManoObra @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  rubroProyectoId String
  rubroProyecto   RubroProyecto    @relation(fields: [rubroProyectoId], references: [id], onDelete: Cascade)

  @@id([contratoId, rubroProyectoId])
  @@map("contrato_rubro_proyecto")
}

/// Personal dentro de una cuadrilla
model PersonalCuadrilla {
  id        String  @id @default(cuid())
  nombre    String
  apellido  String
  dni       String?
  rol       String  // Oficial, Medio Oficial, Ayudante, etc.
  telefono  String?

  contratoId String
  contrato   ContratoManoObra @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@map("personal_cuadrilla")
}

/// Pagos realizados a un contrato
model PagoContrato {
  id          String   @id @default(cuid())
  monto       Float
  fecha       DateTime
  descripcion String?
  comprobante String?  // Ruta o número de comprobante

  contratoId String
  contrato   ContratoManoObra @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@map("pago_contrato")
}

// ============================================================
// MÓDULO 5 — MAQUINARIAS Y LOGÍSTICA (COSTOS INDIRECTOS)
// ============================================================

enum TipoCostoIndirecto {
  FLETE
  ALQUILER_MAQUINARIA
  HONORARIOS_PROYECTO
  GASTO_ADMINISTRATIVO
  SEGURO
  OTRO
}

/// Costo Indirecto del proyecto (separado de materiales)
model CostoIndirecto {
  id          String              @id @default(cuid())
  descripcion String
  tipo        TipoCostoIndirecto
  monto       Float
  proveedor   String?
  fecha       DateTime?
  comprobante String?

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@map("costo_indirecto")
}

// ============================================================
// MÓDULO 6 — EXPORTACIÓN Y PLAN DE PAGOS
// ============================================================

enum EstadoCuota {
  PENDIENTE
  PAGADA
  VENCIDA
}

/// Cuota del Plan de Pagos flexible (N cuotas porcentuales)
/// La suma de porcentaje de todas las cuotas de un proyecto debe ser 100
model CuotaPago {
  id          String      @id @default(cuid())
  numeroCuota Int         // 1, 2, 3...N
  porcentaje  Float       // % del total del presupuesto que representa esta cuota
  // montoCalculado = (presupuesto_total * porcentaje / 100) — calculado en runtime
  descripcion String?     // "Anticipo", "Al completar estructura", "Final de obra", etc.
  fechaEstimada DateTime?
  estado      EstadoCuota @default(PENDIENTE)
  fechaPago   DateTime?   // Fecha real de pago

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  movimientos MovimientoFinanciero[]

  @@map("cuota_pago")
}

// ============================================================
// MÓDULO 1 EXTENDIDO — GESTIÓN DE PROYECTO
// ============================================================

enum EstadoReunion {
  PROGRAMADA
  REALIZADA
  CANCELADA
}

/// Reuniones con propietarios u otras partes interesadas
model Reunion {
  id              String        @id @default(cuid())
  fecha           DateTime
  hora            String?       // "10:30"
  lugar           String?
  temas           String?       // Agenda / temas a tratar
  acta            String?       // Resumen de la reunión (texto libre)
  estado          EstadoReunion @default(PROGRAMADA)
  representantes  String?       // Nombres del equipo que asistirá (texto libre)

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reunion")
}

enum CategoriaAnotacion {
  REUNION
  MODIFICACION
  AJUSTE
  NOTA_LEGAL
  OTRO
}

/// Bitácora de anotaciones del proyecto
model Anotacion {
  id        String             @id @default(cuid())
  fecha     DateTime           @default(now())
  hora      String?
  categoria CategoriaAnotacion @default(OTRO)
  titulo    String
  contenido String
  autor     String?

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("anotacion")
}

/// Datos de aprobación y formalización del proyecto
model AprobacionProyecto {
  id String @id @default(cuid())

  // Datos contractuales
  fechaInicioContractual DateTime?
  fechaFinContractual    DateTime?
  plazoEnDias            Int?
  montoContratoGs        Float?

  // Aprobación de Planos
  fechaAprobacionPlanos    DateTime?
  firmanteAprobacionPlanos String?
  obsAprobacionPlanos      String?

  // Aprobación de Presupuesto
  fechaAprobacionPres    DateTime?
  firmanteAprobacionPres String?
  obsAprobacionPres      String?

  // Aprobado por
  aprobadoPor String?

  // Revisión / Fiscalización
  revisorNombre    String?
  revisorProfesion String?
  fechaRevision    DateTime?
  obsRevision      String?

  // Responsable del Presupuesto
  respPresupuesto          String?
  respPresupuestoProfesion String?

  proyectoId String   @unique
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("aprobacion_proyecto")
}

// ============================================================
// AUTENTICACIÓN — USUARIOS DEL SISTEMA
// ============================================================

enum RolUsuario {
  ADMIN
  USUARIO
}

model Usuario {
  id        String     @id @default(cuid())
  email     String     @unique
  nombre    String
  apellido  String     @default("")
  password  String     // bcrypt hash
  rol       RolUsuario @default(USUARIO)
  activo    Boolean    @default(true)

  // 2FA / TOTP
  totpEnabled       Boolean @default(false)
  totpSecret        String? // TOTP secret activo (base32)
  totpPendingSecret String? // Secret en proceso de configuración (pre-confirmación)

  empresaId String?
  empresa   Empresa?   @relation(fields: [empresaId], references: [id])

  permisos               PermisoModulo[]
  sesiones               SesionHistorial[]
  movimientosAutorizados MovimientoFinanciero[] @relation("MovimientosAutorizados")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
  @@map("usuario")
}

// ============================================================
// GESTIÓN DE USUARIOS — PERMISOS POR MÓDULO
// ============================================================

enum ModuloSistema {
  PROYECTO
  PRESUPUESTO
  CRONOGRAMA
  FINANCIERO
  MANO_OBRA
  LOGISTICA
  COMPRAS
  INVENTARIO
  BITACORA
  REPORTES
}

// ============================================================
// MÓDULO 9 — INVENTARIO / AS-BUILT
// ============================================================

/// Zonificación de la obra: ambientes o espacios físicos
model AmbienteProyecto {
  id     String @id @default(cuid())
  nombre String // Ej: "Cocina", "Baño Suite", "Living-Comedor"

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  // Registros de instalación que referencian este ambiente
  asBuiltRegistros AsBuiltRegistro[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ambiente_proyecto")
}

/// Entrada de materiales a bodega de obra
/// Captura la trazabilidad completa por remisión/lote
model RecepcionBodega {
  id               String   @id @default(cuid())
  fechaRecepcion   DateTime @default(now())
  cantidadRecibida Float
  nroRemision      String?  // Número de remisión del proveedor

  // Trazabilidad de acabados
  marca            String?  // Marca del producto
  modeloSKU        String?  // SKU o código de modelo
  nroLote          String?  // Número de lote de fabricación

  // Especificación para materiales a granel
  especificacionTecnica String? // Ej: "Granulometría 4ta", "Lavada de río"

  // Responsable de recepción
  responsableReceptor String? // Nombre del capataz/encargado

  proyectoId  String
  proyecto    Proyecto        @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  materialId  String
  material    MaterialMaestro @relation(fields: [materialId], references: [id])

  proveedorId String?
  proveedor   Proveedor?      @relation(fields: [proveedorId], references: [id])

  // Salidas (registros de instalación As-Built)
  asBuiltRegistros AsBuiltRegistro[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([proyectoId])
  @@index([materialId])
  @@map("recepcion_bodega")
}

/// Registro de instalación As-Built: cruza ambiente con lote de material
/// Es la "Data Cruda" para Facility Management
model AsBuiltRegistro {
  id                  String   @id @default(cuid())
  fechaInstalacion    DateTime @default(now())
  cantidadInstalada   Float
  dosificacionOMezcla String?  // Ej: "3A + 1B", "Pintura con 30cc entonador"
  mecanismoInstalacion String? // Ej: "Doble encolado", "Soplete", "Vaciado"

  ambienteId  String
  ambiente    AmbienteProyecto @relation(fields: [ambienteId], references: [id], onDelete: Cascade)

  recepcionId String
  recepcion   RecepcionBodega  @relation(fields: [recepcionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("as_built_registro")
}


// ============================================================
// MÓDULO 10 — BITÁCORA DE OBRA
// ============================================================

/// Entrada diaria del libro de obra — nivel profesional (SWOT + personal + rubros)
model BitacoraEntrada {
  id               String   @id @default(cuid())
  fecha            DateTime
  horaInicio       String?  // "07:00"
  horaFin          String?  // "17:00"
  turno            String?  // "Mañana", "Tarde", "Completo"

  // Condiciones del día
  clima            String?  // "Soleado", "Lluvioso", "Nublado", "Ventoso"
  temperatura      Float?   // °C

  // Actividades del día
  descripcionGeneral String  // Resumen obligatorio de lo ejecutado

  // FODA del día
  aspectosPositivos  String? // Logros, buenas prácticas
  aspectosNegativos  String? // Problemas, incidentes, retrasos
  oportunidades      String? // Mejoras detectadas, situaciones favorables
  amenazas           String? // Riesgos, factores externos adversos

  // Seguimiento
  observaciones      String? // Notas adicionales / instrucciones para mañana
  enlaceFotos        String? // URL a carpeta Drive/Dropbox con fotos del día
  responsableFirma   String? // Nombre del fiscal/encargado que carga la entrada

  proyectoId  String
  proyecto    Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  rubrosDelDia    BitacoraRubro[]
  personalDelDia  BitacoraPersonal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([proyectoId])
  @@index([proyectoId, fecha])
  @@map("bitacora_entrada")
}

/// Trabajo específico ejecutado en la jornada
model BitacoraRubro {
  id          String  @id @default(cuid())
  descripcion String  // "Colocación de ladrillo en muro perimetral"
  cantidad    Float?  // Cantidad ejecutada
  unidad      String? // "m²", "m³", "u", "kg"
  avancePct   Float?  // % de avance en ese rubro (0–100)
  observacion String?

  entradaId   String
  entrada     BitacoraEntrada @relation(fields: [entradaId], references: [id], onDelete: Cascade)

  @@map("bitacora_rubro")
}

/// Personal presente en la jornada
model BitacoraPersonal {
  id            String  @id @default(cuid())
  nombre        String
  categoria     String? // "Albañil", "Oficial", "Peón", "Electricista", "Plomero"
  horasTrabajadas Float? // 8.0, 4.5, etc.
  observacion   String?

  entradaId     String
  entrada       BitacoraEntrada @relation(fields: [entradaId], references: [id], onDelete: Cascade)

  @@map("bitacora_personal")
}

/// Control granular: qué módulos puede acceder cada usuario USUARIO
/// Los ADMIN tienen acceso total implícito (no se usan permisos)
model PermisoModulo {
  id        String        @id @default(cuid())
  modulo    ModuloSistema

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, modulo])
  @@index([usuarioId])
  @@map("permiso_modulo")
}

/// Historial de inicio de sesión por usuario
model SesionHistorial {
  id        String   @id @default(cuid())
  fechaHora DateTime @default(now())
  ipAddress String?
  userAgent String?

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([fechaHora])
  @@map("sesion_historial")
}

// ============================================================
// MÓDULO 7 — ESTADO FINANCIERO (LIBRO MAYOR)
// ============================================================

/// Tipo granular de movimiento financiero
/// El prefijo INGRESO_ / EGRESO_ indica dirección del flujo
enum TipoMovimiento {
  INGRESO_CLIENTE       // Cobro al propietario/cliente
  EGRESO_PROVEEDOR      // Pago a proveedor de materiales
  EGRESO_PERSONAL       // Pago a mano de obra / cuadrillas
  EGRESO_MAQUINARIA     // Alquiler de maquinaria / combustible
  EGRESO_HONORARIO      // Honorarios profesionales (arquitecto, ing, etc.)
  EGRESO_CAJA_CHICA     // Gastos menores sin factura formal
  EGRESO_OTRO           // Cualquier otro egreso
}

enum MetodoPago {
  EFECTIVO
  CHEQUE
  TRANSFERENCIA
  GIRO
  OTRO
}

enum TipoComprobante {
  FACTURA
  RECIBO
  REMISION
  TICKET
  OTRO
}

/// Movimiento financiero del Libro Mayor (Ingreso o Egreso por proyecto)
/// El saldo se calcula en runtime — no se persiste para evitar inconsistencias
model MovimientoFinanciero {
  id                 String         @id @default(cuid())
  fecha              DateTime
  tipo               TipoMovimiento
  concepto           String         // Descripción del movimiento
  beneficiario       String         // A quién se pagó / de quién se recibió
  monto              Float

  // Comprobante
  tipoComprobante    TipoComprobante?
  nroComprobante     String?         // N° de factura, recibo, remisión, etc.

  // Auditoría
  autorizadoPor      String?         // Nombre de quien autorizó el pago
  realizadoPor       String?         // Nombre de quien ejecutó físicamente el pago

  // Vinculación con Mano de Obra (sincronización bidireccional)
  codigoPersonal     String?         // Código del trabajador en el módulo Mano de Obra

  metodoPago         MetodoPago
  otroMetodoDetalle  String?         // Descripción libre si metodoPago = OTRO

  // Campos para CHEQUE
  nroCheque          String?
  bancoCheque        String?
  fechaEmisionCheque DateTime?
  fechaCobroCheque   DateTime?       // Fecha real de cobro/depósito del cheque

  // Campos para TRANSFERENCIA / GIRO
  nroTransaccion     String?
  bancoTransfer      String?

  observacion        String?

  // Relación principal
  proyectoId         String
  proyecto           Proyecto             @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  // Relaciones opcionales de trazabilidad
  proveedorId            String?
  proveedor              Proveedor?        @relation(fields: [proveedorId], references: [id])

  cuotaPagoId            String?
  cuotaPago              CuotaPago?        @relation(fields: [cuotaPagoId], references: [id])

  contratoManoObraId     String?
  contratoManoObra       ContratoManoObra? @relation(fields: [contratoManoObraId], references: [id])

  autorizadoPorUsuarioId String?
  autorizadoPorUsuario   Usuario?          @relation("MovimientosAutorizados", fields: [autorizadoPorUsuarioId], references: [id])

  // Facturas pagadas con este movimiento
  facturasPagadas        FacturaProveedor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([proyectoId])
  @@index([proyectoId, fecha])
  @@index([tipo])
  @@map("movimiento_financiero")
}

// ============================================================
// MÓDULO 8 — PROVEEDORES Y COMPRAS
// ============================================================

enum EstadoFactura {
  PENDIENTE
  PAGADA
  ANULADA
}

/// Proveedor global de la empresa (reutilizable en todos los proyectos)
model Proveedor {
  id               String  @id @default(cuid())
  razonSocial      String
  ruc              String? // RUC / CUIT / N° de identificación legal
  tipoPersona      String  @default("JURIDICA") // FISICA | JURIDICA
  direccion        String? // Dirección física del proveedor
  emailEmpresa     String? // Email institucional de la empresa
  vendedores       String? // Nombres de vendedores de contacto (texto libre)
  contactoNombre   String?
  contactoTelefono String?
  contactoEmail    String?
  banco            String?
  tipoCuenta       String? // AHORRO | CORRIENTE
  numeroCuenta     String?
  observaciones    String?
  activo           Boolean @default(true)

  empresaId   String
  empresa     Empresa @relation(fields: [empresaId], references: [id])

  facturas    FacturaProveedor[]
  movimientos MovimientoFinanciero[]
  recepcionesBodega RecepcionBodega[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
  @@map("proveedor")
}

/// Factura de proveedor asociada a un proyecto
/// montoPagado se actualiza al registrar movimientos vinculados
model FacturaProveedor {
  id               String        @id @default(cuid())
  nroFactura       String
  fecha            DateTime
  concepto         String        // Ej: "15 bolsas de cemento"
  monto            Float         // Monto total de la factura
  montoPagado      Float         @default(0)
  estado           EstadoFactura @default(PENDIENTE)
  fechaVencimiento DateTime?
  observacion      String?

  proveedorId  String
  proveedor    Proveedor @relation(fields: [proveedorId], references: [id])

  proyectoId   String
  proyecto     Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  // Movimiento financiero con el que se pagó (null = aún sin pagar)
  movimientoId String?
  movimiento   MovimientoFinanciero? @relation(fields: [movimientoId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([proyectoId])
  @@index([proveedorId])
  @@index([estado])
  @@map("factura_proveedor")
}

// ============================================================
// AUDITORÍA — REGISTRO INMUTABLE DE ACCIONES CRÍTICAS
// ============================================================

enum AccionAudit {
  USUARIO_REGISTRO
  USUARIO_CREADO
  USUARIO_ACTIVADO
  USUARIO_DESACTIVADO
  USUARIO_ELIMINADO
  USUARIO_PASSWORD_CAMBIADO
  USUARIO_2FA_HABILITADO
  USUARIO_2FA_DESHABILITADO
  PROYECTO_CREADO
  PROYECTO_EDITADO
  PROYECTO_ELIMINADO
  MOVIMIENTO_CREADO
  MOVIMIENTO_ELIMINADO
}

/// Registro inmutable de auditoría de seguridad
/// Nunca se eliminan registros — solo INSERT
model AuditLog {
  id         String      @id @default(cuid())
  timestamp  DateTime    @default(now())

  // Quién realizó la acción
  userId     String?     // id del usuario que actuó (null = acción anónima)
  userEmail  String?     // email (desnormalizado para conservarlo si el usuario se elimina)

  // Qué hizo
  accion     AccionAudit
  entidad    String      // "Usuario", "Proyecto", "MovimientoFinanciero", etc.
  entidadId  String?     // id del registro afectado

  // Datos del cambio (snapshot JSON)
  antes      Json?       // Estado previo (para ediciones/bajas)
  despues    Json?       // Estado posterior (para altas/ediciones)

  // Contexto de red
  ip         String?
  userAgent  String?

  exito      Boolean     @default(true)
  error      String?     // Mensaje de error si exito = false

  @@index([userId])
  @@index([accion])
  @@index([timestamp])
  @@map("audit_log")
}
